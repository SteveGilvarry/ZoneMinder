# ==========================================================================
#
# ZoneMinder Stream Socket Configuration
#
# ==========================================================================
#
# Settings for the per-monitor media stream sockets
# (ZM_PATH_SOCKS/stream_{monitor_id}.sock) served by zmc.
#
# *** DO NOT EDIT THIS FILE ***
#
# To make custom changes to the variables below, create a new configuration
# file, with an extension of .conf, containing your desired modifications.
#

# Group ownership applied to the stream socket files. Sockets are created
# with mode 0660, so members of this group can consume monitor media without
# running as the web user. Leave empty to keep the default group.
ZM_STREAM_SOCKET_GROUP=@ZM_WEB_GROUP@

# Optional comma-separated list of numeric user ids allowed to connect to
# the stream sockets, verified via SO_PEERCRED. Empty allows any user that
# passes the filesystem permissions.
ZM_STREAM_SOCKET_ALLOWED_UIDS=

# Maximum number of simultaneous consumers per monitor stream socket.
ZM_STREAM_SOCKET_MAX_CLIENTS=8

# Per-consumer outgoing queue limits. When a slow consumer's queue is full
# the oldest media messages are dropped for that consumer only; the loss is
# reported through sequence number gaps and STATS messages.
ZM_STREAM_SOCKET_QUEUE_BYTES=8388608
ZM_STREAM_SOCKET_QUEUE_MSGS=256

# Disconnect a consumer that has accepted no data for this many seconds
# while its queue is full.
ZM_STREAM_SOCKET_STALL_SECS=10
